								<i class="fa fa-user"></i> <b>Sigit Hariyadi</b>, 
								<i class="fas fa-university"></i> Universitas Negeri Semarang, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
																				<li class="list-item consent mb-2">
								<i class="fa fa-user"></i> <b>Susantika Dwy</b>, 
								<i class="fas fa-university"></i> Universitas Negeri Semarang, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
