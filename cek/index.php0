																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
																				<li class="list-item consent mb-2">
								<i class="fa fa-user"></i> <b>Martunis Yahya</b>, 
								<i class="fas fa-university"></i> Universitas Syah Kuala, Banda Aceh, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
																				<li class="list-item consent mb-2">
								<i class="fa fa-user"></i> <b>Wan Chalidaziah</b>, 
								<i class="fas fa-university"></i> Institut Agama Islam Negeri Langsa, Banda Aceh, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
