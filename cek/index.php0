			<a class="summary_title" href="https://counselor.ppj.unp.ac.id/index.php/konselor/article/view/159">
				Profiling Creative Competence, Cultural Literacy, and Career Readiness among Guidance and Counseling Students as a Basis for Developing a Digital-Art and Local-Wisdom Learning Model
			</a>
		</div>
		 
							<div class="meta_authors">
										<ul class="meta_author_list list-unstyled mb-0"> 
																				<li class="list-item consent mb-2">
								<i class="fa fa-user"></i> <b>Vira Afriyati</b>, 
								<i class="fas fa-university"></i> Universitas Bengkulu, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
																				<li class="list-item consent mb-2">
								<i class="fa fa-user"></i> <b>Arsyadani Misbahudin</b>, 
								<i class="fas fa-university"></i> Universitas Bengkulu, 
																	<i class="fas fa-globe-asia"></i>&nbspIndonesia
															</li>
											</ul>
				</div>
						<div class="summary_meta">	
